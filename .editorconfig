root = true

# Global defaults — LF line endings everywhere for cross-platform consistency
[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true

# Java and C# — 4-space indent is the established convention in both ecosystems
[*.{java,cs}]
indent_style = space
indent_size = 4

# TypeScript, HTML, JSON, YAML — 2-space is standard in the JS/web ecosystem
[*.{ts,html,json,yaml,yml}]
indent_style = space
indent_size = 2

# .NET project files inherit 2-space to keep XML readable
[*.{csproj,props,targets}]
indent_style = space
indent_size = 2

# Maven POM — 4-space matches IntelliJ/Maven defaults
[pom.xml]
indent_style = space
indent_size = 4

# CSS files
[*.css]
indent_style = space
indent_size = 2

# Markdown — no trailing whitespace trimming (double-space = intentional line break)
[*.md]
trim_trailing_whitespace = false
