# Copy this file to .env and fill in real values before running docker compose up.
# NEVER commit .env — it is in .gitignore.

USER_DB_CONNECTION=Server=sqlserver;Database=UserServiceDb;User Id=<service-user>;Password=<password>;TrustServerCertificate=True
DISCOVERY_DB_URL=jdbc:sqlserver://sqlserver:1433;databaseName=DiscoveryServiceDb;encrypt=true;trustServerCertificate=true
CONNECTION_DB_URL=jdbc:sqlserver://sqlserver:1433;databaseName=ConnectionServiceDb;encrypt=true;trustServerCertificate=true
CHAT_DB_CONNECTION=mongodb://mongodb:27017/ChatServiceDb
RATING_DB_URL=jdbc:sqlserver://sqlserver:1433;databaseName=RatingServiceDb;encrypt=true;trustServerCertificate=true
NOTIFICATION_DB_CONNECTION=Server=sqlserver;Database=NotificationServiceDb;User Id=<service-user>;Password=<password>;TrustServerCertificate=True
REPORT_MONGODB_URI=mongodb://mongodb:27017/ReportServiceDb
ADMIN_DB_URL=jdbc:sqlserver://sqlserver:1433;databaseName=AdminServiceDb;encrypt=true;trustServerCertificate=true
SA_PASSWORD=<strong-password-here>
JWT_SECRET=<jwt-secret-here>
GOOGLE_CLIENT_ID=<google-oauth-client-id>
FCM_PROJECT_ID=<firebase-project-id>
KAFKA_BOOTSTRAP=kafka:9092
REDIS_HOST=redis
REDIS_CONNECTION=redis:6379
