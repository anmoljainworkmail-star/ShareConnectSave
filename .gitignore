# =============================================================================
# Docker / Infrastructure
# =============================================================================
# IMPORTANT: Never commit secrets to source control.
# All connection strings, API keys, and passwords live in .env only.
.env
.env.local
.env.*.local
*.env

# Docker override files that contain local-only settings
docker-compose.local.yml

# =============================================================================
# OS / Editor artifacts
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# VSCode (keep .vscode/extensions.json and launch.json but not personal settings)
.vscode/settings.json

# JetBrains IDEs
.idea/

